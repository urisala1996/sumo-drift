{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      "$code": {
        ".validate": "$code.matches(/^[A-HJ-NP-Z]{4}$/)",
        ".write": "!data.exists() || !newData.exists()",

        "meta": {
          ".read": true,
          ".write": true,
          "host":        { ".validate": "newData.isString() && newData.val().length == 36 && (!data.exists() || data.val() == newData.val())" },
          "status":      { ".validate": "newData.val() == 'lobby' || newData.val() == 'playing'" },
          "phase":       { ".validate": "newData.isString() && newData.val().length <= 20" },
          "phaseT":      { ".validate": "newData.isNumber()" },
          "ring":        { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "round":       { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20" },
          "matchId":     { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "banner":      { ".validate": "newData.isString() && newData.val().length <= 60" },
          "bannerColor": { ".validate": "newData.isString() && newData.val().length <= 12" },
          "fillAI":      { ".validate": "newData.isBoolean()" },
          "map":         { ".validate": "newData.isString() && newData.val().length <= 24" },
          "ringSize":    { ".validate": "newData.val() == 'small' || newData.val() == 'medium' || newData.val() == 'large'" },
          "sd":          { ".validate": "newData.isNumber() && newData.val() >= -1 && newData.val() <= 60" },
          "hostSeen":    { ".validate": "newData.isNumber()" },
          "createdAt":   { ".validate": "newData.isNumber()" },
          "$other":      { ".validate": false }
        },

        "players": {
          ".read": true,
          "$clientId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','slot','car','ready'])",
            "name":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20" },
            "slot":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" },
            "car":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" },
            "ready":  { ".validate": "newData.isBoolean()" },
            "seen":   { ".validate": "newData.isNumber()" },
            "online": { ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },

        "inputs": {
          ".read": true,
          "$clientId": {
            ".write": true,
            "l": { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "r": { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "b": { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "$other": { ".validate": false }
          }
        },

        "state": {
          ".read": true,
          ".write": true,
          "$slot": {
            ".validate": "$slot.matches(/^[0-3]$/)",
            "x":       { ".validate": "newData.isNumber() && newData.val() >= -150 && newData.val() <= 150" },
            "z":       { ".validate": "newData.isNumber() && newData.val() >= -150 && newData.val() <= 150" },
            "y":       { ".validate": "newData.isNumber() && newData.val() >= -60  && newData.val() <= 60"  },
            "heading": { ".validate": "newData.isNumber()" },
            "steer":   { ".validate": "newData.isNumber() && newData.val() >= -1.6 && newData.val() <= 1.6" },
            "alive":   { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "falling": { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "brake":   { ".validate": "newData.val() == 0 || newData.val() == 1" },
            "wins":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20" },
            "$other":  { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
